# ============================================================================
# AutoParts B2B — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` for local dev. On Vercel, set every variable below
# in the project's "Environment Variables" UI (Production + Preview scopes).
# ============================================================================

# ─── Database (Neon Postgres) ────────────────────────────────────────────────
#
# Two URLs are required:
#   • DATABASE_URL  — pooled connection used by the app at runtime. The
#                     hostname MUST contain "-pooler" (e.g. ep-XXX-pooler).
#                     Neon copies this from "Connection Pooling" tab.
#   • DIRECT_URL    — direct (non-pooled) connection used ONLY for Prisma
#                     migrations. Required because pooled connections do not
#                     support DDL transactions.
#
# Both should include `?sslmode=require`.
#
# To get them: Neon dashboard → your project → "Connection details" panel.
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXX.REGION.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth / Auth.js v5 ───────────────────────────────────────────────────
#
# AUTH_SECRET — long random string used to sign JWTs. Generate with:
#     openssl rand -base64 32
# Treat like a password — rotating it logs every user out.
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# AUTH_URL — only required in production. On Vercel, set this to the canonical
# domain (e.g. https://autoparts.example.com). In local dev it is auto-detected
# from the request and can be left unset.
# AUTH_URL="https://autoparts.example.com"

# ─── Vercel Blob (product image storage) ─────────────────────────────────────
#
# Create a Blob store in the Vercel dashboard → Storage tab → Create Database
# → Blob. The token is shown once; copy it here.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── 1C ↔ AutoParts integration ──────────────────────────────────────────────

# Shared secret for the PUSH endpoints at /api/sync/1c/*. Pick a long random
# hex string (32+ chars). 1C will send this in the X-Sync-Token header.
#     openssl rand -hex 32
ONEC_SYNC_TOKEN="change-me-to-a-32-char-hex-string"

# OPTIONAL: pull configuration. When set, the Vercel cron job at
# /api/cron/sync-1c (runs every 30 min) GETs ${ONEC_PULL_URL}/{type} for
# each of products|stock|prices|categories|customers using the configured
# Authorization header. Leave empty to keep the cron a no-op.
ONEC_PULL_URL=""
ONEC_PULL_AUTH=""

# CRON_SECRET — used to authenticate calls to /api/cron/sync-1c. Vercel Cron
# automatically attaches `Authorization: Bearer ${CRON_SECRET}` to every cron
# invocation. Set this to a long random string and Vercel will pick it up.
# Vercel docs: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET="change-me-to-another-32-char-hex-string"

# ─── Initial admin (seed only — never runs on production builds) ─────────────
#
# Used by `npm run db:seed`. Ignored by `prisma migrate deploy`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="change-me-immediately"
SEED_ADMIN_NAME="Administrator"

# ─── Storefront branding (compiled into the client bundle) ───────────────────
NEXT_PUBLIC_CURRENCY="AZN"
NEXT_PUBLIC_SITE_NAME="AutoParts B2B"

# ─── Optional production toggles ─────────────────────────────────────────────

# Set to "true" in a non-prod Vercel preview to expose /admin/debug/analytics.
# In production this page is hidden (returns 404) regardless of role unless
# this flag is explicitly set.
# ENABLE_DEBUG_PAGES="false"
